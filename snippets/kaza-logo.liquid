{% doc %}
  Renders the KAZA logo image or wordmark fallback.

  @param {image} [logo] - Theme editor logo override
  @param {string} [text] - Accessible label fallback
  @param {string} [class] - Additional CSS classes for the link
{% enddoc %}

{% liquid
  assign logo_alt = text | default: shop.name
  assign default_logo_asset = 'logo.webp'
%}

<a href="{{ routes.root_url }}" class="kaza-logo{% if class != blank %} {{ class }}{% endif %}">
  {% if logo != blank %}
    {{ logo | image_url: width: 240 | image_tag: alt: logo_alt, class: 'kaza-logo__image', widths: '120, 180, 240' }}
  {% else %}
    <img
      src="{{ default_logo_asset | asset_url }}"
      alt="{{ logo_alt | escape }}"
      class="kaza-logo__image"
      width="120"
      height="32"
      loading="eager"
    >
  {% endif %}
</a>

{% stylesheet %}
  .kaza-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: #e5e5e5;
    flex-shrink: 0;
  }

  .kaza-logo__image {
    display: block;
    max-height: 1.75rem;
    width: auto;
  }
{% endstylesheet %}
