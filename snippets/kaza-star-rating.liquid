{% doc %}
  Renders a star rating display.

  @param {number} rating - Rating value (1-5)
  @param {string} [label] - Accessible label text
{% enddoc %}

{% liquid
  assign star_count = rating | default: 5 | round
  if star_count > 5
    assign star_count = 5
  endif
  if star_count < 0
    assign star_count = 0
  endif
%}

<div class="kaza-stars" role="img" aria-label="{{ label | default: 'Rating' }}: {{ star_count }} out of 5">
  {% for i in (1..5) %}
    {% if i <= star_count %}
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
    {% else %}
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" style="opacity:0.25"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
    {% endif %}
  {% endfor %}
</div>
