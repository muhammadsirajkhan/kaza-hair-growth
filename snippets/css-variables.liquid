{% style %}
  @font-face {
    font-family: 'Satoshi';
    src: url('{{ 'Satoshi-Regular.woff2' | asset_url }}') format('woff2'),
      url('{{ 'Satoshi-Regular.woff' | asset_url }}') format('woff');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Satoshi';
    src: url('{{ 'Satoshi-Medium.woff2' | asset_url }}') format('woff2'),
      url('{{ 'Satoshi-Medium.woff' | asset_url }}') format('woff');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Satoshi';
    src: url('{{ 'Satoshi-Bold.woff2' | asset_url }}') format('woff2'),
      url('{{ 'Satoshi-Bold.woff' | asset_url }}') format('woff');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --font-primary--family: 'Satoshi', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --font-primary--style: normal;
    --font-primary--weight: 400;
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;
    --color-background: {{ settings.background_color }};
    --color-foreground: {{ settings.foreground_color }};
    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;
    --kaza-beige: {{ settings.kaza_beige }};
    --kaza-gold: {{ settings.kaza_gold }};
    --kaza-black: {{ settings.kaza_accent_black }};
  }
{% endstyle %}
