{% liquid
  assign consistency_card = section.blocks | where: 'type', 'consistency_card' | first
  assign step_blocks = section.blocks | where: 'type', 'step'
  assign men_card = section.blocks | where: 'type', 'men_card' | first
%}

<section
  class="kaza-product-promo full-width"
  {% if section.settings.section_id != blank %}id="{{ section.settings.section_id | handleize }}"{% endif %}
>
  <div class="kaza-container">
    <div class="kaza-product-promo__grid">
      {% if consistency_card %}
        <article class="kaza-product-promo__card kaza-product-promo__card--left" {{ consistency_card.shopify_attributes }}>
          <div class="kaza-product-promo__content">
            {% if consistency_card.settings.heading_prefix != blank or consistency_card.settings.heading_highlight != blank %}
              <h2 class="kaza-product-promo__heading">
                {% if consistency_card.settings.heading_prefix != blank %}
                  <span class="kaza-section-heading__prefix">{{ consistency_card.settings.heading_prefix }}</span>
                {% endif %}
                {% if consistency_card.settings.heading_highlight != blank %}
                  <span class="kaza-section-heading__highlight">{{ consistency_card.settings.heading_highlight }}</span>
                {% endif %}
              </h2>
            {% endif %}

            {% if consistency_card.settings.text != blank %}
              <p class="kaza-product-promo__text">{{ consistency_card.settings.text }}</p>
            {% endif %}

            {% if step_blocks.size > 0 %}
              {% if consistency_card.settings.steps_heading != blank %}
                <h3 class="kaza-product-promo__steps-heading">{{ consistency_card.settings.steps_heading }}</h3>
              {% endif %}

              <ol class="kaza-product-promo__steps">
                {% for block in step_blocks %}
                  {% if block.settings.text != blank %}
                    <li class="kaza-product-promo__step" {{ block.shopify_attributes }}>
                      <span>{{ block.settings.text }}</span>
                    </li>
                  {% endif %}
                {% endfor %}
              </ol>
            {% endif %}
          </div>

          <div class="kaza-product-promo__media kaza-product-promo__media--left">
            {% if consistency_card.settings.image != blank %}
              {{ consistency_card.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: consistency_card.settings.heading_highlight | default: consistency_card.settings.heading_prefix }}
            {% else %}
              <img
                src="{{ 'left-new.webp' | asset_url }}"
                alt="{{ consistency_card.settings.heading_highlight | default: consistency_card.settings.heading_prefix | escape }}"
                width="900"
                height="700"
                loading="lazy"
              >
            {% endif %}
          </div>
        </article>
      {% endif %}

      {% if men_card %}
        {% liquid
          assign men_bg = men_card.settings.background_image
          if men_bg == blank
            assign men_bg_fallback = 'right-new.webp'
          endif
        %}
        <article class="kaza-product-promo__card kaza-product-promo__card--right" {{ men_card.shopify_attributes }}>
          <div class="kaza-product-promo__bg" aria-hidden="true">
            {% if men_bg != blank %}
              {{ men_bg | image_url: width: 1200 | image_tag: loading: 'lazy', alt: '' }}
            {% else %}
              <img
                src="{{ men_bg_fallback | asset_url }}"
                alt=""
                width="1200"
                height="1043"
                loading="lazy"
              >
            {% endif %}
          </div>

          <div class="kaza-product-promo__content">
            {% if men_card.settings.heading_prefix != blank or men_card.settings.heading_highlight != blank %}
              <h2 class="kaza-product-promo__heading">
                {% if men_card.settings.heading_prefix != blank %}
                  <span class="kaza-section-heading__prefix">{{ men_card.settings.heading_prefix }}</span>
                {% endif %}
                {% if men_card.settings.heading_highlight != blank %}
                  <span class="kaza-section-heading__highlight">{{ men_card.settings.heading_highlight }}</span>
                {% endif %}
              </h2>
            {% endif %}

            {% if men_card.settings.subheading != blank %}
              <p class="kaza-product-promo__subheading">{{ men_card.settings.subheading }}</p>
            {% endif %}
          </div>

          {% if men_card.settings.show_badges %}
            <div class="kaza-product-promo__badges" aria-hidden="true">
              {% if men_card.settings.badge_1_text != blank %}
                <div class="kaza-product-promo__badge kaza-product-promo__badge--1">
                  {% if men_card.settings.badge_1_icon != blank %}
                    {{ men_card.settings.badge_1_icon | image_url: width: 32 | image_tag: loading: 'lazy', alt: '' }}
                  {% else %}
                    <img src="{{ 'choose-icon4.webp' | asset_url }}" alt="" width="14" height="14" loading="lazy">
                  {% endif %}
                  <span>{{ men_card.settings.badge_1_text }}</span>
                </div>
              {% endif %}

              {% if men_card.settings.badge_2_text != blank %}
                <div class="kaza-product-promo__badge kaza-product-promo__badge--2">
                  {% if men_card.settings.badge_2_icon != blank %}
                    {{ men_card.settings.badge_2_icon | image_url: width: 32 | image_tag: loading: 'lazy', alt: '' }}
                  {% else %}
                    <img src="{{ 'choose-icon3.webp' | asset_url }}" alt="" width="14" height="14" loading="lazy">
                  {% endif %}
                  <span>{{ men_card.settings.badge_2_text }}</span>
                </div>
              {% endif %}

              {% if men_card.settings.badge_3_text != blank %}
                <div class="kaza-product-promo__badge kaza-product-promo__badge--3">
                  {% if men_card.settings.badge_3_icon != blank %}
                    {{ men_card.settings.badge_3_icon | image_url: width: 32 | image_tag: loading: 'lazy', alt: '' }}
                  {% else %}
                    <img src="{{ 'choose-icon1.webp' | asset_url }}" alt="" width="14" height="14" loading="lazy">
                  {% endif %}
                  <span>{{ men_card.settings.badge_3_text }}</span>
                </div>
              {% endif %}
            </div>
          {% endif %}
        </article>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.kaza_product_promo.name",
  "blocks": [
    {
      "type": "consistency_card",
      "name": "t:sections.kaza_product_promo.blocks.consistency_card.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading_prefix",
          "label": "t:labels.heading_prefix",
          "default": "Visible results "
        },
        {
          "type": "text",
          "id": "heading_highlight",
          "label": "t:labels.heading_highlight",
          "default": "with consistency"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "Use 1–2× daily on clean, dry scalp. Most users report improved density with less shedding over 8–12 weeks of consistent use. Individual results vary."
        },
        {
          "type": "text",
          "id": "steps_heading",
          "label": "t:sections.kaza_product_promo.settings.steps_heading",
          "default": "How to Apply"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        }
      ]
    },
    {
      "type": "step",
      "name": "t:sections.kaza_product_promo.blocks.step.name",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text",
          "default": "After shower or before bed, apply to target areas."
        }
      ]
    },
    {
      "type": "men_card",
      "name": "t:sections.kaza_product_promo.blocks.men_card.name",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "t:labels.background_image"
        },
        {
          "type": "text",
          "id": "heading_prefix",
          "label": "t:labels.heading_prefix",
          "default": "Built for "
        },
        {
          "type": "text",
          "id": "heading_highlight",
          "label": "t:labels.heading_highlight",
          "default": "men"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:labels.subheading",
          "default": "Key Actives — Rootalix™ • Caffeine • Rosemary"
        },
        {
          "type": "checkbox",
          "id": "show_badges",
          "label": "t:sections.kaza_product_promo.settings.show_badges",
          "default": true
        },
        {
          "type": "text",
          "id": "badge_1_text",
          "label": "t:sections.kaza_product_promo.settings.badge_1_text",
          "default": "non-oily, fast dry-down subtle finish"
        },
        {
          "type": "image_picker",
          "id": "badge_1_icon",
          "label": "t:sections.kaza_product_promo.settings.badge_1_icon"
        },
        {
          "type": "text",
          "id": "badge_2_text",
          "label": "t:sections.kaza_product_promo.settings.badge_2_text",
          "default": "Fragrance: none added"
        },
        {
          "type": "image_picker",
          "id": "badge_2_icon",
          "label": "t:sections.kaza_product_promo.settings.badge_2_icon"
        },
        {
          "type": "text",
          "id": "badge_3_text",
          "label": "t:sections.kaza_product_promo.settings.badge_3_text",
          "default": "Philosophy: For men, by men."
        },
        {
          "type": "image_picker",
          "id": "badge_3_icon",
          "label": "t:sections.kaza_product_promo.settings.badge_3_icon"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "t:labels.section_id",
      "info": "t:labels.section_id_info",
      "default": "product-promo"
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_product_promo.name",
      "blocks": [
        {
          "type": "consistency_card"
        },
        {
          "type": "step",
          "settings": {
            "text": "1. After shower or before bed, apply to target areas."
          }
        },
        {
          "type": "step",
          "settings": {
            "text": "2. Massage 10–20 seconds."
          }
        },
        {
          "type": "step",
          "settings": {
            "text": "3. Leave on—no rinse."
          }
        },
        {
          "type": "step",
          "settings": {
            "text": "4. Track progress with monthly photos (same lighting/angle)."
          }
        },
        {
          "type": "men_card",
          "settings": {
            "show_badges": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
