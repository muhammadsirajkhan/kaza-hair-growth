<section class="kaza-rootalix full-width">
  <div class="kaza-rootalix__bg" aria-hidden="true">
    {% if section.settings.background_image != blank %}
      {{ section.settings.background_image | image_url: width: 2400 | image_tag: loading: 'lazy', alt: '' }}
    {% else %}
      <img
        src="{{ 'powered-bg.webp' | asset_url }}"
        alt=""
        width="2400"
        height="1400"
        loading="lazy"
      >
    {% endif %}
  </div>
  <div class="kaza-rootalix__overlay" aria-hidden="true"></div>

  <div class="kaza-container kaza-rootalix__inner">
    <div class="kaza-rootalix__header kaza-section-intro kaza-section-intro--dark">
      {% if section.settings.show_rating %}
        <div class="kaza-rootalix__rating">
          {% render 'kaza-star-rating', rating: section.settings.rating, label: section.settings.rating_text %}
          {% if section.settings.rating_text != blank %}
            <span class="kaza-rootalix__rating-text">{{ section.settings.rating_text }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.heading_prefix != blank or section.settings.heading_highlight != blank %}
        <h2 class="kaza-section-heading">
          {% if section.settings.heading_prefix != blank %}
            <span class="kaza-section-heading__prefix">{{ section.settings.heading_prefix }}</span>
          {% endif %}
          {% if section.settings.heading_highlight != blank %}
            <span class="kaza-section-heading__highlight">{{ section.settings.heading_highlight }}</span>
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="kaza-section-subheading kaza-section-subheading--light">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <div class="kaza-rootalix__visual">
      {% if section.settings.product_image != blank %}
        <div class="kaza-rootalix__product">
          {{ section.settings.product_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.heading_highlight }}
        </div>
      {% endif %}

      <div class="kaza-rootalix__features">
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            {% liquid
              assign feature_icon = block.settings.icon
              if feature_icon == blank
                case block.settings.position
                  when 'top-left'
                    assign feature_icon_fallback = 'choose-icon1.webp'
                  when 'bottom-left'
                    assign feature_icon_fallback = 'choose-icon2.webp'
                  when 'top-right'
                    assign feature_icon_fallback = 'choose-icon3.webp'
                  when 'bottom-right'
                    assign feature_icon_fallback = 'choose-icon4.webp'
                  else
                    assign feature_icon_fallback = 'choose-icon1.webp'
                endcase
              endif
            %}
            <div
              class="kaza-rootalix__feature kaza-rootalix__feature--{{ block.settings.position }}"
              {{ block.shopify_attributes }}
            >
              {% liquid
                assign is_left = false
                if block.settings.position == 'top-left' or block.settings.position == 'bottom-left'
                  assign is_left = true
                endif
              %}

              {% if is_left and block.settings.title != blank %}
                <p class="kaza-rootalix__feature-text">{{ block.settings.title }}</p>
              {% endif %}

              {% unless is_left %}
                <div class="kaza-rootalix__feature-icon">
                  {% if feature_icon != blank %}
                    {{ feature_icon | image_url: width: 64 | image_tag: loading: 'lazy', alt: '' }}
                  {% else %}
                    <img
                      src="{{ feature_icon_fallback | asset_url }}"
                      alt=""
                      width="24"
                      height="24"
                      loading="lazy"
                    >
                  {% endif %}
                </div>
              {% endunless %}

              <div class="kaza-rootalix__feature-line" aria-hidden="true"></div>

              {% if is_left %}
                <div class="kaza-rootalix__feature-icon">
                  {% if feature_icon != blank %}
                    {{ feature_icon | image_url: width: 64 | image_tag: loading: 'lazy', alt: '' }}
                  {% else %}
                    <img
                      src="{{ feature_icon_fallback | asset_url }}"
                      alt=""
                      width="24"
                      height="24"
                      loading="lazy"
                    >
                  {% endif %}
                </div>
              {% endif %}

              {% unless is_left %}
                {% if block.settings.title != blank %}
                  <p class="kaza-rootalix__feature-text">{{ block.settings.title }}</p>
                {% endif %}
              {% endunless %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if section.settings.ingredients != blank %}
      <div class="kaza-rootalix__footer">
        <div class="kaza-rootalix__divider" aria-hidden="true"></div>
        <p class="kaza-rootalix__ingredients">{{ section.settings.ingredients }}</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.kaza_rootalix.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "t:sections.kaza_rootalix.settings.show_rating",
      "default": true
    },
    {
      "type": "range",
      "id": "rating",
      "label": "t:labels.rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "t:labels.rating_text",
      "default": "5000+ Verified 5-star Reviews"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "t:sections.kaza_rootalix.settings.heading_prefix",
      "default": "Powered by"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "t:sections.kaza_rootalix.settings.heading_highlight",
      "default": "Rootalix™"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.kaza_rootalix.settings.description",
      "default": "Rootalix™ is Alfin Labs' proprietary active complex designed to support thicker hair and reduce shedding, built for daily, leave-on use and a modern men's routine. No prescriptions, no heaviness, just clean, cosmetic science that fits your life."
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "t:labels.product_image",
      "info": "t:sections.kaza_rootalix.settings.product_image_info"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:labels.background_image"
    },
    {
      "type": "textarea",
      "id": "ingredients",
      "label": "t:sections.kaza_rootalix.settings.ingredients",
      "default": "Powered by: DHQG • EGCG • Zinc PCA • Oleanolic Acid • Apigenin • Biotinoyl Tripeptide-1 (2.0% total inclusion)"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.kaza_rootalix.blocks.feature.name",
      "settings": [
        {
          "type": "select",
          "id": "position",
          "label": "t:labels.position",
          "options": [
            { "value": "top-left", "label": "t:options.position.top_left" },
            { "value": "bottom-left", "label": "t:options.position.bottom_left" },
            { "value": "top-right", "label": "t:options.position.top_right" },
            { "value": "bottom-right", "label": "t:options.position.bottom_right" }
          ],
          "default": "top-left"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Thicker strands over time"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_rootalix.name",
      "blocks": [
        { "type": "feature", "settings": { "position": "top-left", "title": "Thicker strands over time" } },
        { "type": "feature", "settings": { "position": "bottom-left", "title": "Less shedding on brush and in shower" } },
        { "type": "feature", "settings": { "position": "top-right", "title": "Healthier scalp feel and appearance" } },
        { "type": "feature", "settings": { "position": "bottom-right", "title": "Visible Density Improvements." } }
      ]
    }
  ]
}
{% endschema %}
