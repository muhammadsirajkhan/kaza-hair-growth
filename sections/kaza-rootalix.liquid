<section class="kaza-rootalix full-width">
  <div class="kaza-rootalix__bg">
    {% if section.settings.background_image != blank %}
      {{ section.settings.background_image | image_url: width: 2400 | image_tag: loading: 'lazy', alt: '' }}
    {% endif %}
  </div>
  <div class="kaza-rootalix__overlay"></div>

  <div class="kaza-container kaza-rootalix__inner">
    <div class="kaza-rootalix__header">
      <svg class="kaza-rootalix__star" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {% if section.settings.heading != blank %}
        <h2 class="kaza-section-heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="kaza-rootalix__visual">
      {% if section.settings.product_image != blank %}
        <div class="kaza-rootalix__product">
          {{ section.settings.product_image | image_url: width: 500 | image_tag: loading: 'lazy', alt: section.settings.heading }}
        </div>
      {% endif %}

      <div class="kaza-rootalix__features">
        {% for block in section.blocks %}
          <div class="kaza-rootalix__feature kaza-rootalix__feature--{{ block.settings.position }}" {{ block.shopify_attributes }}>
            <div class="kaza-rootalix__feature-dot"></div>
            <div class="kaza-rootalix__feature-content">
              {% if block.settings.title != blank %}
                <h3>{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p>{{ block.settings.text }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>


{% schema %}
{
  "name": "t:sections.kaza_rootalix.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Powered by Rootalix™"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "t:labels.product_image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:labels.background_image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.kaza_rootalix.blocks.feature.name",
      "settings": [
        {
          "type": "select",
          "id": "position",
          "label": "t:labels.position",
          "options": [
            { "value": "top-left", "label": "t:options.position.top_left" },
            { "value": "bottom-left", "label": "t:options.position.bottom_left" },
            { "value": "top-right", "label": "t:options.position.top_right" },
            { "value": "bottom-right", "label": "t:options.position.bottom_right" }
          ],
          "default": "top-left"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Reduces hair loss"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_rootalix.name",
      "blocks": [
        { "type": "feature", "settings": { "position": "top-left", "title": "Reduces hair loss" } },
        { "type": "feature", "settings": { "position": "bottom-left", "title": "Promotes growth" } },
        { "type": "feature", "settings": { "position": "top-right", "title": "Strengthens roots" } },
        { "type": "feature", "settings": { "position": "bottom-right", "title": "Nourishes scalp" } }
      ]
    }
  ]
}
{% endschema %}
