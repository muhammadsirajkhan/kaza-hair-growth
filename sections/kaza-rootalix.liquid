<section class="kaza-rootalix full-width">
  <div class="kaza-rootalix__bg">
    {% if section.settings.background_image != blank %}
      {{ section.settings.background_image | image_url: width: 2400 | image_tag: loading: 'lazy', alt: '' }}
    {% endif %}
  </div>
  <div class="kaza-rootalix__overlay"></div>

  <div class="kaza-container kaza-rootalix__inner">
    <div class="kaza-rootalix__header">
      <svg class="kaza-rootalix__star" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {% if section.settings.heading != blank %}
        <h2 class="kaza-section-heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="kaza-rootalix__visual">
      {% if section.settings.product_image != blank %}
        <div class="kaza-rootalix__product">
          {{ section.settings.product_image | image_url: width: 500 | image_tag: loading: 'lazy', alt: section.settings.heading }}
        </div>
      {% endif %}

      <div class="kaza-rootalix__features">
        {% for block in section.blocks %}
          <div class="kaza-rootalix__feature kaza-rootalix__feature--{{ block.settings.position }}" {{ block.shopify_attributes }}>
            <div class="kaza-rootalix__feature-dot"></div>
            <div class="kaza-rootalix__feature-content">
              {% if block.settings.title != blank %}
                <h3>{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p>{{ block.settings.text }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .kaza-rootalix {
    position: relative;
    padding-block: var(--kaza-section-y);
    background: var(--kaza-black);
    color: var(--kaza-white);
    overflow: hidden;
  }

  .kaza-rootalix__bg {
    position: absolute;
    inset: 0;
    opacity: 0.3;
  }

  .kaza-rootalix__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .kaza-rootalix__overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center top, rgba(255, 255, 255, 0.08) 0%, transparent 60%);
  }

  .kaza-rootalix__inner {
    position: relative;
    z-index: 1;
  }

  .kaza-rootalix__header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
    text-align: center;
  }

  .kaza-rootalix__star {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--kaza-gold);
  }

  .kaza-rootalix__visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 420px;
  }

  .kaza-rootalix__product {
    position: relative;
    z-index: 2;
  }

  .kaza-rootalix__product img {
    max-height: 360px;
    width: auto;
    filter: drop-shadow(0 0 60px rgba(196, 162, 101, 0.25));
  }

  .kaza-rootalix__features {
    position: absolute;
    inset: 0;
  }

  .kaza-rootalix__feature {
    position: absolute;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    max-width: 200px;
  }

  .kaza-rootalix__feature--top-left { top: 5%; left: 5%; }
  .kaza-rootalix__feature--bottom-left { bottom: 15%; left: 5%; }
  .kaza-rootalix__feature--top-right { top: 5%; right: 5%; text-align: right; flex-direction: row-reverse; }
  .kaza-rootalix__feature--bottom-right { bottom: 15%; right: 5%; text-align: right; flex-direction: row-reverse; }

  .kaza-rootalix__feature-dot {
    flex-shrink: 0;
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    background: var(--kaza-gold);
    margin-top: 0.375rem;
    box-shadow: 0 0 12px var(--kaza-gold);
  }

  .kaza-rootalix__feature-content h3 {
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .kaza-rootalix__feature-content p {
    font-size: 0.8125rem;
    line-height: 1.5;
    opacity: 0.75;
  }

  @media (max-width: 767px) {
    .kaza-rootalix__visual {
      flex-direction: column;
      min-height: auto;
      gap: 2rem;
    }

    .kaza-rootalix__features {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .kaza-rootalix__feature {
      position: static;
      max-width: none;
      flex-direction: row !important;
      text-align: left !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.kaza_rootalix.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Powered by Rootalix™"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "t:labels.product_image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:labels.background_image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.kaza_rootalix.blocks.feature.name",
      "settings": [
        {
          "type": "select",
          "id": "position",
          "label": "t:labels.position",
          "options": [
            { "value": "top-left", "label": "t:options.position.top_left" },
            { "value": "bottom-left", "label": "t:options.position.bottom_left" },
            { "value": "top-right", "label": "t:options.position.top_right" },
            { "value": "bottom-right", "label": "t:options.position.bottom_right" }
          ],
          "default": "top-left"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Reduces hair loss"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_rootalix.name",
      "blocks": [
        { "type": "feature", "settings": { "position": "top-left", "title": "Reduces hair loss" } },
        { "type": "feature", "settings": { "position": "bottom-left", "title": "Promotes growth" } },
        { "type": "feature", "settings": { "position": "top-right", "title": "Strengthens roots" } },
        { "type": "feature", "settings": { "position": "bottom-right", "title": "Nourishes scalp" } }
      ]
    }
  ]
}
{% endschema %}
