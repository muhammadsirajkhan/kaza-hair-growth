<section class="kaza-brand-statement full-width">
  <div class="kaza-container">
    {% if section.settings.text != blank %}
      <p class="kaza-brand-statement__text">{{ section.settings.text }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.kaza_brand_statement.name",
  "settings": [
    {
      "type": "textarea",
      "id": "text",
      "label": "t:labels.text",
      "default": "At KAZA, we believe everyone deserves fuller, healthier hair. Our science-backed formulas combine nature and innovation to deliver visible results — without compromise."
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_brand_statement.name"
    }
  ]
}
{% endschema %}
