<div class="kaza-hero full-width" data-kaza-hero>
  <div class="kaza-hero__slides">
    {% assign slide_count = 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'slide' %}
        {% assign slide_count = slide_count | plus: 1 %}
        <div
          class="kaza-hero__slide{% if slide_count == 1 %} is-active{% endif %}"
          data-kaza-hero-slide
          {{ block.shopify_attributes }}>
          {% liquid
            assign hero_background = block.settings.background_image
            assign hero_background_alt = block.settings.heading | default: shop.name
          %}
          <div class="kaza-hero__bg">
            {% if hero_background != blank %}
              {{ hero_background | image_url: width: 2400 | image_tag: loading: 'eager', fetchpriority: 'high', alt: hero_background_alt }}
            {% else %}
              <img
                src="{{ 'hero.webp' | asset_url }}"
                alt="{{ hero_background_alt | escape }}"
                loading="eager"
                fetchpriority="high"
                width="2400"
                height="1200">
            {% endif %}
          </div>

          <div class="kaza-hero__content_wrap">
            <div class="kaza-hero__content kaza-container">
              <div class="kaza-hero__left">
                {% if block.settings.heading != blank %}
                  <h1 class="kaza-hero__heading">{{ block.settings.heading }}</h1>
                {% endif %}
                {% if block.settings.subheading != blank %}
                  <p class="kaza-hero__subheading">{{ block.settings.subheading }}</p>
                {% endif %}
                {% if block.settings.button_label != blank %}
                  <div class="kaza-hero__cta-row">
                    <a href="{{ block.settings.button_url | default: routes.all_products_collection_url }}" class="kaza-btn kaza-btn--invert kaza-btn--rect kaza-hero__cta">
                      {{ block.settings.button_label }}
                      <svg
                        class="kaza-hero__cta-icon"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        aria-hidden="true">
                        <path
                          d="M6 6h15l-1.5 9h-12z"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linejoin="round" />
                        <path
                          d="M6 6 5 3H2"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round" />
                        <circle
                          cx="9"
                          cy="20"
                          r="1.25"
                          fill="currentColor" />
                        <circle
                          cx="18"
                          cy="20"
                          r="1.25"
                          fill="currentColor" />
                      </svg>
                    </a>
                    {% if block.settings.powered_by_text != blank %}
                      <span class="kaza-hero__powered">{{ block.settings.powered_by_text }}</span>
                    {% endif %}
                  </div>
                {% endif %}
                {% if section.settings.show_trust_bar %}
                  <div class="kaza-hero__trust">
                    {% if section.settings.trust_text != blank %}
                      <span class="kaza-hero__trust-label">{{ section.settings.trust_text }}</span>
                    {% endif %}
                    <div class="kaza-hero__trust-logos">
                      {% if section.settings.show_trustpilot %}
                        <span class="kaza-hero__trustpilot" aria-label="Trustpilot">
                          <svg
                            class="kaza-hero__trustpilot-star"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            aria-hidden="true"><path fill="#00B67A" d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
                          <span class="kaza-hero__trustpilot-text">Trustpilot</span>
                        </span>
                      {% endif %}
                      {% if section.settings.show_google %}
                        <span class="kaza-hero__google" aria-label="Google">
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            width="18"
                            height="18"
                            aria-hidden="true">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                          </svg>
                        </span>
                      {% endif %}
                      {% render 'kaza-star-rating'
                        , rating: section.settings.trust_rating
                        , label: section.settings.trust_text %}
                    </div>
                  </div>
                {% endif %}
              </div>
              <div class="kaza-hero__right">
                {% if block.settings.product_image != blank %}
                  <div class="kaza-hero__product">
                    {{ block.settings.product_image | image_url: width: 800 | image_tag: loading: 'eager', alt: block.settings.heading }}
                  </div>
                {% endif %}
                {% assign feature_blocks = section.blocks | where: 'type', 'feature' %}
                {% if feature_blocks.size > 0 %}
                  <div class="kaza-hero__features">
                    {% assign feature_index = 0 %}
                    {% for feature in feature_blocks %}
                      {% assign feature_index = feature_index | plus: 1 %}
                      {% liquid
                        assign feature_icon = feature.settings.icon
                        if feature_icon == blank
                          case feature_index
                            when 1
                              assign feature_icon_fallback = 'h1.webp'
                            when 2
                              assign feature_icon_fallback = 'h2.webp'
                            when 3
                              assign feature_icon_fallback = 'h3.webp'
                            else
                              assign feature_icon_fallback = 'h1.webp'
                          endcase
                        endif
                      %}
                      <div class="kaza-hero__feature" {{ feature.shopify_attributes }}>
                        <div class="kaza-hero__feature-icon">
                          {% if feature_icon != blank %}
                            {{ feature_icon | image_url: width: 80 | image_tag: loading: 'lazy', alt: '' }}
                          {% else %}
                            <img
                              src="{{ feature_icon_fallback | asset_url }}"
                              alt=""
                              width="80"
                              height="80"
                              loading="lazy"
                            >
                          {% endif %}
                        </div>
                        <div class="kaza-hero__feature-body">
                          {% if feature.settings.title != blank %}
                            <h2 class="kaza-hero__feature-title">{{ feature.settings.title }}</h2>
                          {% endif %}
                          {% if feature.settings.text != blank %}
                            <p class="kaza-hero__feature-text">{{ feature.settings.text }}</p>
                          {% endif %}
                        </div>
                      </div>
                      {% unless forloop.last %}
                        <hr class="kaza-hero__feature-divider">
                      {% endunless %}
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.show_slider_controls %}
    <div class="kaza-hero__controls kaza-container">
      <button
        type="button"
        class="kaza-hero__nav-btn"
        data-kaza-hero-next
        aria-label="{{ 'general.accessibility.next' | t }}">
        ← {{ 'sections.kaza_hero.next' | t }}
      </button>
      <button
        type="button"
        class="kaza-hero__nav-btn"
        data-kaza-hero-prev
        aria-label="{{ 'general.accessibility.previous' | t }}">
        {{ 'sections.kaza_hero.prev' | t }} →
      </button>
    </div>
  {% endif %}
</div>


{% javascript %}
  (function() {
    const hero = document.querySelector('[data-kaza-hero]');
      if (! hero) return;
      

      const slides = [... hero.querySelectorAll('[data-kaza-hero-slide]')];
      if (slides.length<= 1) return;

    let current = 0;

    const update = () => {
        slides.forEach((slide, i) => slide.classList.toggle('is-active', i === current));
      };

      hero.querySelector('[data-kaza-hero-prev]') ?. addEventListener('click', () => {
        current = (current - 1 + slides.length) % slides.length;
        update();
      });

      hero.querySelector('[data-kaza-hero-next]') ?. addEventListener('click', () => {
        current = (current + 1) % slides.length;
        update();
      });
    }
  )();
{% endjavascript %}

{% schema %}
  {
    "name": "t:sections.kaza_hero.name",
    "max_blocks": 8,
    "settings": [
      {
        "type": "checkbox",
        "id": "show_trust_bar",
        "label": "t:sections.kaza_hero.settings.show_trust_bar",
        "default": true
      },
      {
        "type": "text",
        "id": "trust_text",
        "label": "t:sections.kaza_hero.settings.trust_text",
        "default": "Excellent 683 reviews on"
      },
      {
        "type": "range",
        "id": "trust_rating",
        "label": "t:labels.rating",
        "min": 1,
        "max": 5,
        "step": 1,
        "default": 5
      },
      {
        "type": "checkbox",
        "id": "show_trustpilot",
        "label": "t:sections.kaza_hero.settings.show_trustpilot",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_google",
        "label": "t:sections.kaza_hero.settings.show_google",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_slider_controls",
        "label": "t:sections.kaza_hero.settings.show_slider_controls",
        "default": true
      }
    ],
    "blocks": [
      {
        "type": "slide",
        "name": "t:sections.kaza_hero.blocks.slide.name",
        "settings": [
          {
            "type": "image_picker",
            "id": "background_image",
            "label": "t:labels.background_image"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "t:labels.heading",
            "default": "Up to 28,200+ new hairs in 3 months."
          },
          {
            "type": "textarea",
            "id": "subheading",
            "label": "t:labels.subheading",
            "default": "Based on a 3-month clinical study where participants saw an average of 10,000 new hairs and a maximum of 28,200."
          },
          {
            "type": "text",
            "id": "button_label",
            "label": "t:labels.button_label",
            "default": "Shop the Serum"
          }, {
            "type": "url",
            "id": "button_url",
            "label": "t:labels.button_url"
          }, {
            "type": "text",
            "id": "powered_by_text",
            "label": "t:sections.kaza_hero.settings.powered_by_text",
            "default": "Powered by Rootalix™"
          }, {
            "type": "image_picker",
            "id": "product_image",
            "label": "t:labels.product_image",
            "info": "t:sections.kaza_hero.settings.product_image_info"
          }
        ]
      }, {
        "type": "feature",
        "name": "t:sections.kaza_hero.blocks.feature.name",
        "settings": [
          {
            "type": "image_picker",
            "id": "icon",
            "label": "t:labels.icon"
          }, {
            "type": "text",
            "id": "title",
            "label": "t:labels.title",
            "default": "92% success rate"
          }, {
            "type": "textarea",
            "id": "text",
            "label": "t:labels.text",
            "default": "92% of users saw a visible reduction in shedding within 4 weeks."
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "t:sections.kaza_hero.name",
        "blocks": [
          {
            "type": "slide"
          }, {
            "type": "feature",
            "settings": {
              "title": "92% success rate",
              "text": "92% of users saw a visible reduction in shedding within 4 weeks."
            }
          }, {
            "type": "feature",
            "settings": {
              "title": "Zero side effect",
              "text": "Zero side effects. No hormonal disruption. No impact on sex drive."
            }
          }, {
            "type": "feature",
            "settings": {
              "title": "Botanical-powered",
              "text": "Saw Palmetto, Green Tea, Larch Wood, Oleanolic Acid"
            }
          }
        ]
      }
    ]
  }
{% endschema %}