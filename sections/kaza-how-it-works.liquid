<section
  class="kaza-how-it-works full-width"
  {% if section.settings.section_id != blank %}id="{{ section.settings.section_id | handleize }}"{% endif %}
>
  <div class="kaza-container">
    <div class="kaza-how-it-works__header kaza-section-intro">
      {% if section.settings.badge_text != blank %}
        <span class="kaza-section-pill">{{ section.settings.badge_text }}</span>
      {% endif %}

      {% if section.settings.heading_prefix != blank or section.settings.heading_highlight != blank %}
        <h2 class="kaza-section-heading">
          {% if section.settings.heading_prefix != blank %}
            <span class="kaza-section-heading__prefix">{{ section.settings.heading_prefix }}</span>
          {% endif %}
          {% if section.settings.heading_highlight != blank %}
            <span class="kaza-section-heading__highlight">{{ section.settings.heading_highlight }}</span>
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="kaza-section-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="kaza-how-it-works__steps">
      {% assign step_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
          {% assign step_index = step_index | plus: 1 %}
          {% liquid
            assign step_image = block.settings.image
            if step_image == blank
              case step_index
                when 1
                  assign step_image_fallback = 'image-1.webp'
                when 2
                  assign step_image_fallback = 'image-2.webp'
                when 3
                  assign step_image_fallback = 'image-3.webp'
                else
                  assign step_image_fallback = 'image-1.webp'
              endcase
            endif
          %}
          <article class="kaza-how-it-works__step" {{ block.shopify_attributes }}>
            <div class="kaza-how-it-works__step-media">
              {% if step_image != blank %}
                {{ step_image | image_url: width: 480 | image_tag: loading: 'lazy', alt: block.settings.title }}
              {% else %}
                <img
                  src="{{ step_image_fallback | asset_url }}"
                  alt="{{ block.settings.title | escape }}"
                  width="480"
                  height="480"
                  loading="lazy"
                >
              {% endif %}
            </div>
            {% if block.settings.title != blank %}
              <h3 class="kaza-how-it-works__step-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="kaza-how-it-works__step-text">{{ block.settings.text }}</p>
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="kaza-how-it-works__cta">
        <a
          href="{{ section.settings.button_url | default: routes.all_products_collection_url }}"
          class="kaza-btn kaza-btn--primary kaza-how-it-works__cta-btn"
        >
          {{ section.settings.button_label }}
          <img src="{{ 'white-cart.png' | asset_url }}" alt="">
          
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.kaza_how_it_works.name",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "t:labels.section_id",
      "info": "t:labels.section_id_info",
      "default": "how-it-works"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:sections.kaza_how_it_works.settings.badge_text",
      "default": "Welcome to Kaza"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "t:sections.kaza_how_it_works.settings.heading_prefix",
      "default": "How it"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "t:sections.kaza_how_it_works.settings.heading_highlight",
      "default": "Works"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Real performance. Visible results. Made for men who want impact, not excuses."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Shop the Serum"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.kaza_how_it_works.blocks.step.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Block"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "Topical DHT Defense (Oleanolic Acid)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_how_it_works.name",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Block",
            "text": "Topical DHT Defense (Oleanolic Acid)"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Anchor",
            "text": "Biotinoyl Tripeptide-1."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Grow",
            "text": "Redensyl (DHQG + EGCG)."
          }
        }
      ]
    }
  ]
}
{% endschema %}
