<section class="kaza-how-it-works full-width">
  <div class="kaza-container">
    {% if section.settings.heading != blank %}
      <h2 class="kaza-section-heading kaza-how-it-works__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="kaza-section-subheading kaza-how-it-works__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="kaza-how-it-works__steps">
      {% for block in section.blocks %}
        <div class="kaza-how-it-works__step" {{ block.shopify_attributes }}>
          <div class="kaza-how-it-works__step-media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% else %}
              {{ 'image' | placeholder_svg_tag }}
            {% endif %}
          </div>
          {% if block.settings.step_number != blank %}
            <span class="kaza-how-it-works__step-num">{{ block.settings.step_number }}</span>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="kaza-how-it-works__step-title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="kaza-how-it-works__step-text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="kaza-how-it-works__cta">
        {% render 'kaza-button', label: section.settings.button_label, url: section.settings.button_url, style: 'primary' %}
      </div>
    {% endif %}
  </div>
</section>


{% schema %}
{
  "name": "t:sections.kaza_how_it_works.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "How it works"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Get started"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.kaza_how_it_works.blocks.step.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "step_number",
          "label": "t:labels.step_number",
          "default": "Step 1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Apply"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "Apply a few drops directly to your scalp each evening."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_how_it_works.name",
      "blocks": [
        { "type": "step", "settings": { "step_number": "Step 1", "title": "Apply", "text": "Apply a few drops directly to your scalp each evening." } },
        { "type": "step", "settings": { "step_number": "Step 2", "title": "Absorb", "text": "Rootalix™ penetrates deep into hair follicles." } },
        { "type": "step", "settings": { "step_number": "Step 3", "title": "Grow", "text": "Watch new, healthy hair emerge within 90 days." } }
      ]
    }
  ]
}
{% endschema %}
