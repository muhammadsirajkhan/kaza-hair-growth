{% liquid
  assign testimonial_blocks = section.blocks | where: 'type', 'testimonial'
  assign benefit_blocks = section.blocks | where: 'type', 'benefit'
%}

<section class="kaza-challenge full-width" data-kaza-challenge>
  <div class="kaza-challenge__upper">
    <div class="kaza-container">
      <div class="kaza-challenge__header kaza-section-intro">
        {% if section.settings.badge_text != blank %}
          <span class="kaza-section-pill">{{ section.settings.badge_text }}</span>
        {% endif %}

        {% if section.settings.heading_prefix != blank or section.settings.heading_highlight != blank %}
          <h2 class="kaza-section-heading">
            {% if section.settings.heading_prefix != blank %}
              <span class="kaza-section-heading__prefix">{{ section.settings.heading_prefix }}</span>
            {% endif %}
            {% if section.settings.heading_highlight != blank %}
              <span class="kaza-section-heading__highlight">{{ section.settings.heading_highlight }}</span>
            {% endif %}
          </h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="kaza-section-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>

      <div class="kaza-challenge__comparison">
        {% render 'kaza-before-after',
          before_image: section.settings.before_image,
          after_image: section.settings.after_image,
          before_fallback: 'before.webp',
          after_fallback: 'after.webp',
          handle_text: section.settings.handle_label,
          initial_position: section.settings.initial_position
        %}
      </div>
    </div>
  </div>

  {% if testimonial_blocks.size > 0 or benefit_blocks.size > 0 %}
    <div class="kaza-challenge__lower">
      <div class="kaza-container">
        {% if testimonial_blocks.size > 0 %}
          <div class="kaza-challenge__reviews" data-kaza-reviews>
            <div class="kaza-challenge__reviews-shell">
              {% if testimonial_blocks.size > 1 %}
                <button
                  type="button"
                  class="kaza-challenge__reviews-arrow kaza-challenge__reviews-arrow--prev"
                  data-kaza-reviews-prev
                  aria-label="{{ 'general.accessibility.previous' | t }}"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                </button>
              {% endif %}

              <div class="kaza-challenge__reviews-viewport">
                <div class="kaza-challenge__reviews-track" data-kaza-reviews-track>
                  {% for block in testimonial_blocks %}
                    <article
                      class="kaza-challenge__review{% if forloop.first %} is-active{% endif %}"
                      data-kaza-review
                      {{ block.shopify_attributes }}
                    >
                      <div class="kaza-challenge__review-content">
                        <svg class="kaza-challenge__quote-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 32" width="40" height="32" aria-hidden="true">
                          <path fill="currentColor" d="M0 20.8C0 13.6 3.6 8 10.4 4l2.4 3.6C7.2 10.8 5.6 13.6 5.6 16.8h6.4V32H0V20.8zm20 0C20 13.6 23.6 8 30.4 4l2.4 3.6c-5.6 3.2-7.2 6-7.2 9.2h6.4V32H20V20.8z"/>
                        </svg>

                        {% render 'kaza-star-rating', rating: block.settings.rating, label: block.settings.title %}

                        {% if block.settings.title != blank %}
                          <h3 class="kaza-challenge__review-title">{{ block.settings.title }}</h3>
                        {% endif %}

                        {% if block.settings.quote != blank %}
                          <blockquote class="kaza-challenge__review-quote">&ldquo;{{ block.settings.quote }}&rdquo;</blockquote>
                        {% endif %}
                      </div>
                    </article>
                  {% endfor %}
                </div>
              </div>

              {% if testimonial_blocks.size > 1 %}
                <button
                  type="button"
                  class="kaza-challenge__reviews-arrow kaza-challenge__reviews-arrow--next"
                  data-kaza-reviews-next
                  aria-label="{{ 'general.accessibility.next' | t }}"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                </button>
              {% endif %}
            </div>

            {% if testimonial_blocks.size > 1 %}
              <div class="kaza-challenge__pagination" data-kaza-reviews-pagination role="tablist" aria-label="{{ 'sections.kaza_challenge.pagination_label' | t }}">
                {% for block in testimonial_blocks %}
                  <button
                    type="button"
                    class="kaza-challenge__pagination-bar{% if forloop.first %} is-active{% endif %}"
                    data-kaza-reviews-dot
                    role="tab"
                    aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                    aria-label="{{ 'sections.kaza_challenge.go_to_review' | t: number: forloop.index }}"
                  ></button>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if benefit_blocks.size > 0 %}
          <div class="kaza-challenge__stats">
            {% for block in benefit_blocks %}
              <article class="kaza-card kaza-challenge__stat-card" {{ block.shopify_attributes }}>
                {% if block.settings.title != blank %}
                  <h3 class="kaza-challenge__stat-title">{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p class="kaza-challenge__stat-text">{{ block.settings.text }}</p>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}
</section>

{% javascript %}
  (function () {
    document.querySelectorAll('[data-kaza-ba-slider]').forEach((slider) => {
      const control = slider.querySelector('[data-kaza-ba-control]');
      const viewport = slider.querySelector('.kaza-ba-slider__viewport');
      if (!control || !viewport) return;

      let position = parseFloat(getComputedStyle(slider).getPropertyValue('--kaza-ba-position')) || 50;
      let dragging = false;

      const clamp = (value) => Math.min(100, Math.max(0, value));

      const setPosition = (value) => {
        position = clamp(value);
        slider.style.setProperty('--kaza-ba-position', position + '%');
        control.style.left = position + '%';
        control.setAttribute('aria-valuenow', String(Math.round(position)));
      };

      const updateFromPointer = (clientX) => {
        const rect = viewport.getBoundingClientRect();
        if (!rect.width) return;
        setPosition(((clientX - rect.left) / rect.width) * 100);
      };

      const onPointerMove = (event) => {
        if (!dragging) return;
        updateFromPointer(event.clientX);
      };

      const stopDragging = () => {
        dragging = false;
        slider.classList.remove('is-dragging');
        window.removeEventListener('pointermove', onPointerMove);
        window.removeEventListener('pointerup', stopDragging);
        window.removeEventListener('pointercancel', stopDragging);
      };

      control.addEventListener('pointerdown', (event) => {
        dragging = true;
        slider.classList.add('is-dragging');
        control.setPointerCapture(event.pointerId);
        window.addEventListener('pointermove', onPointerMove);
        window.addEventListener('pointerup', stopDragging);
        window.addEventListener('pointercancel', stopDragging);
      });

      control.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          setPosition(position - 5);
        }
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          setPosition(position + 5);
        }
        if (event.key === 'Home') {
          event.preventDefault();
          setPosition(0);
        }
        if (event.key === 'End') {
          event.preventDefault();
          setPosition(100);
        }
      });
    });

    document.querySelectorAll('[data-kaza-reviews]').forEach((reviews) => {
      const track = reviews.querySelector('[data-kaza-reviews-track]');
      const slides = [...reviews.querySelectorAll('[data-kaza-review]')];
      const dots = [...reviews.querySelectorAll('[data-kaza-reviews-dot]')];
      const viewport = reviews.querySelector('.kaza-challenge__reviews-viewport');
      if (!track || !viewport || slides.length <= 1) return;

      let current = 0;
      let isDragging = false;
      let pointerStartX = 0;
      let pointerDeltaX = 0;
      const swipeThreshold = 48;

      const getStep = () => {
        const slide = slides[0];
        if (!slide) return 0;
        const styles = getComputedStyle(track);
        const gap = parseFloat(styles.columnGap || styles.gap) || 0;
        return slide.offsetWidth + gap;
      };

      const getOffsetForIndex = (index) => {
        const step = getStep();
        const viewportWidth = viewport.offsetWidth;
        const slideWidth = slides[0]?.offsetWidth || 0;
        return index * step - (viewportWidth - slideWidth) / 2;
      };

      const setTrackOffset = (offset, animate = true) => {
        track.style.transition = animate ? '' : 'none';
        track.style.transform = 'translateX(' + (-offset) + 'px)';
      };

      const goTo = (index, { animate = true } = {}) => {
        current = (index + slides.length) % slides.length;
        setTrackOffset(getOffsetForIndex(current), animate);

        slides.forEach((slide, i) => {
          slide.classList.toggle('is-active', i === current);
        });

        dots.forEach((dot, i) => {
          dot.classList.toggle('is-active', i === current);
          dot.setAttribute('aria-selected', i === current ? 'true' : 'false');
        });
      };

      const finishDrag = () => {
        if (!isDragging) return;

        isDragging = false;
        viewport.classList.remove('is-dragging');

        if (Math.abs(pointerDeltaX) >= swipeThreshold) {
          goTo(pointerDeltaX < 0 ? current + 1 : current - 1);
        } else {
          goTo(current);
        }

        pointerDeltaX = 0;
      };

      const onPointerDown = (event) => {
        if (event.pointerType === 'mouse' && event.button !== 0) return;
        if (event.target.closest('[data-kaza-reviews-dot]')) return;

        isDragging = true;
        pointerStartX = event.clientX;
        pointerDeltaX = 0;
        viewport.classList.add('is-dragging');
        viewport.setPointerCapture(event.pointerId);
        setTrackOffset(getOffsetForIndex(current) - pointerDeltaX, false);
      };

      const onPointerMove = (event) => {
        if (!isDragging) return;

        pointerDeltaX = event.clientX - pointerStartX;
        setTrackOffset(getOffsetForIndex(current) - pointerDeltaX, false);
      };

      viewport.addEventListener('pointerdown', onPointerDown);
      viewport.addEventListener('pointermove', onPointerMove);
      viewport.addEventListener('pointerup', finishDrag);
      viewport.addEventListener('pointercancel', finishDrag);

      reviews.querySelector('[data-kaza-reviews-prev]')?.addEventListener('click', () => goTo(current - 1));
      reviews.querySelector('[data-kaza-reviews-next]')?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => goTo(current), 150);
      });

      goTo(0);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.kaza_challenge.name",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:sections.kaza_challenge.settings.badge_text",
      "default": "Welcome to Kaza"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "t:sections.kaza_challenge.settings.heading_prefix",
      "default": "90-Day"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "t:sections.kaza_challenge.settings.heading_highlight",
      "default": "Challenge"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Real performance. Visible results. Made for men who want impact, not excuses."
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "t:labels.before_image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "t:labels.after_image"
    },
    {
      "type": "text",
      "id": "handle_label",
      "label": "t:sections.kaza_challenge.settings.handle_label",
      "default": "Drag"
    },
    {
      "type": "range",
      "id": "initial_position",
      "label": "t:sections.kaza_challenge.settings.initial_position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.kaza_challenge.blocks.testimonial.name",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "t:labels.rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "My Hair Looks Denser"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:labels.quote",
          "default": "My hair looks denser around the front after a few weeks—love the quick dry."
        }
      ]
    },
    {
      "type": "benefit",
      "name": "t:sections.kaza_challenge.blocks.benefit.name",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "92% success rate"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "92% of users saw a visible reduction in shedding within 4 weeks."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_challenge.name",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "title": "My Hair Looks Denser",
            "quote": "My hair looks denser around the front after a few weeks—love the quick dry."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "title": "Finally Found My Type",
            "quote": "A serum that feels legit and clean—exactly the type I was looking for."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "title": "Finally Seeing Results",
            "quote": "I've tried the typical stuff before. This actually works without the hassle."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "92% SUCCESS RATE",
            "text": "92% of users saw a visible reduction in shedding within 4 weeks."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "HORMONE SAFE",
            "text": "No hormonal disruption. No impact on sex drive."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "BOTANICAL POWERED",
            "text": "Saw Palmetto, Green Tea, Larch Wood, Oleanolic Acid"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "12-WEEK DHT SHIELD",
            "text": "Clinical results show peak anchoring and density improvements in weeks 12"
          }
        }
      ]
    }
  ]
}
{% endschema %}
