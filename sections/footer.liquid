  ],
  "presets": [
    {
      "name": "t:sections.kaza_footer.name",
      "blocks": [
        { "type": "nav_link", "settings": { "title": "Plans & Pricing" } },
        { "type": "nav_link", "settings": { "title": "About us" } },
        { "type": "nav_link", "settings": { "title": "Tutorials" } },
        { "type": "nav_link", "settings": { "title": "FAQ" } },
        { "type": "nav_link", "settings": { "title": "Resources" } },
        { "type": "nav_link", "settings": { "title": "Contact" } },
        { "type": "social_link", "settings": { "network": "facebook", "title": "Facebook" } },
        { "type": "social_link", "settings": { "network": "instagram", "title": "Instagram" } },
