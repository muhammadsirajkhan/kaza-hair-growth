<footer class="kaza-footer full-width">
  <div class="kaza-container kaza-footer__main">
    <div class="kaza-footer__brand">
      <a href="{{ routes.root_url }}" class="kaza-footer__logo">{{ section.settings.logo_text | default: 'KAZA™' }}</a>
      {% if section.settings.description != blank %}
        <p class="kaza-footer__description">{{ section.settings.description }}</p>
      {% endif %}

      {% if section.settings.show_newsletter %}
        {% form 'customer', class: 'kaza-footer__newsletter' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="kaza-visually-hidden" for="FooterEmail">{{ 'sections.kaza_footer.email_label' | t }}</label>
          <input
            id="FooterEmail"
            type="email"
            name="contact[email]"
            placeholder="{{ 'sections.kaza_footer.email_placeholder' | t }}"
            required
            autocomplete="email"
          >
          <button type="submit" class="kaza-btn kaza-btn--secondary">{{ 'sections.kaza_footer.join' | t }}</button>
        {% endform %}
      {% endif %}

      {% if section.settings.cta_label != blank %}
        <div class="kaza-footer__cta">
          {% render 'kaza-button', label: section.settings.cta_label, url: section.settings.cta_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>

    {% if section.settings.products_menu != blank %}
      <div class="kaza-footer__column">
        <h3 class="kaza-footer__heading">{{ 'sections.kaza_footer.products' | t }}</h3>
        <ul class="kaza-footer__links">
          {% for link in section.settings.products_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    {% if section.settings.company_menu != blank %}
      <div class="kaza-footer__column">
        <h3 class="kaza-footer__heading">{{ 'sections.kaza_footer.company' | t }}</h3>
        <ul class="kaza-footer__links">
          {% for link in section.settings.company_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    <div class="kaza-footer__column">
      <h3 class="kaza-footer__heading">{{ 'sections.kaza_footer.social_media' | t }}</h3>
      <ul class="kaza-footer__social">
        {% if section.settings.social_instagram != blank %}
          <li>
            <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </a>
          </li>
        {% endif %}
        {% if section.settings.social_facebook != blank %}
          <li>
            <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          </li>
        {% endif %}
        {% if section.settings.social_twitter != blank %}
          <li>
            <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener noreferrer" aria-label="X">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </li>
        {% endif %}
      </ul>
    </div>
  </div>

  <div class="kaza-footer__bar">
    <div class="kaza-container kaza-footer__bar-inner">
      <p class="kaza-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.kaza_footer.all_rights' | t }}
      </p>
      <div class="kaza-footer__legal">
        {% for link in section.settings.legal_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</footer>


{% schema %}
{
  "name": "t:sections.kaza_footer.name",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "t:labels.logo_text",
      "default": "KAZA™"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description",
      "default": "Science-backed hair growth for everyone. Powered by Rootalix™."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "t:sections.kaza_footer.settings.show_newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:labels.cta_label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:labels.cta_url"
    },
    {
      "type": "link_list",
      "id": "products_menu",
      "label": "t:sections.kaza_footer.settings.products_menu"
    },
    {
      "type": "link_list",
      "id": "company_menu",
      "label": "t:sections.kaza_footer.settings.company_menu"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "t:sections.kaza_footer.settings.legal_menu"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "t:labels.social_instagram"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "t:labels.social_facebook"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "t:labels.social_twitter"
    }
  ]
}
{% endschema %}
