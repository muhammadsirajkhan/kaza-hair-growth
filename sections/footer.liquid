<footer class="kaza-footer full-width" data-kaza-footer>
  <div class="kaza-container kaza-footer__main">
    <div class="kaza-footer__brand">
      {% if section.settings.logo != blank %}
        {% render 'kaza-logo', logo: section.settings.logo, text: section.settings.logo_text, class: 'kaza-footer__logo-link' %}
      {% else %}
        <a href="{{ routes.root_url }}" class="kaza-footer__logo">{{ section.settings.logo_text | default: 'KAZA™' }}</a>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="kaza-footer__description">{{ section.settings.description }}</p>
      {% endif %}

      {% if section.settings.cta_label != blank %}
        <a
          href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}"
          class="kaza-btn kaza-btn--rect kaza-btn--invert kaza-footer__cta"
        >
          {{ section.settings.cta_label }}
          <svg class="kaza-footer__cta-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
    </div>

    <div class="kaza-footer__column">
      <h2 class="kaza-footer__heading">{{ section.settings.navigation_heading }}</h2>
      <ul class="kaza-footer__links">
        {% if section.settings.navigation_menu != blank %}
          {% for link in section.settings.navigation_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {% endfor %}
        {% else %}
          {% for block in section.blocks %}
            {% if block.type == 'nav_link' %}
              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.url | default: '#' }}">{{ block.settings.title | escape }}</a>
              </li>
            {% endif %}
          {% endfor %}
        {% endif %}
      </ul>
    </div>

    <div class="kaza-footer__column">
      <h2 class="kaza-footer__heading">{{ section.settings.contact_heading }}</h2>
      <ul class="kaza-footer__contact">
        <li class="kaza-footer__contact-row">
          <span class="kaza-footer__contact-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"><path d="M12 21s7-4.5 7-10a7 7 0 1 0-14 0c0 5.5 7 10 7 10z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="11" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
          </span>
          <span class="kaza-footer__contact-body">
            <span class="kaza-footer__contact-label">{{ section.settings.office_sublabel }}</span>
            <span class="kaza-footer__contact-value">{{ section.settings.office_text }}</span>
          </span>
        </li>
        <li class="kaza-footer__contact-row">
          <span class="kaza-footer__contact-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="m3 7 9 6 9-6" stroke="currentColor" stroke-width="1.5"/></svg>
          </span>
          <span class="kaza-footer__contact-body">
            <span class="kaza-footer__contact-label">{{ section.settings.email_sublabel }}</span>
            {% if section.settings.email != blank %}
              <a href="mailto:{{ section.settings.email }}" class="kaza-footer__contact-value kaza-footer__contact-link">{{ section.settings.email }}</a>
            {% endif %}
          </span>
        </li>
        <li class="kaza-footer__contact-row">
          <span class="kaza-footer__contact-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M3 12h18M12 3c2.5 2.8 3.8 5.8 3.8 9S14.5 18.2 12 21M12 3C9.5 5.8 8.2 8.8 8.2 12s1.3 6.2 3.8 9" stroke="currentColor" stroke-width="1.5"/></svg>
          </span>
          <span class="kaza-footer__contact-body">
            <span class="kaza-footer__contact-label">{{ section.settings.language_sublabel }}</span>
            <span class="kaza-footer__contact-value">{{ section.settings.language_text }}</span>
          </span>
        </li>
      </ul>
    </div>

    <div class="kaza-footer__column">
      <h2 class="kaza-footer__heading">{{ section.settings.social_heading }}</h2>
      <ul class="kaza-footer__social-list">
        {% for block in section.blocks %}
          {% if block.type == 'social_link' %}
            <li {{ block.shopify_attributes }}>
              <a
                href="{{ block.settings.url | default: '#' }}"
                class="kaza-footer__social-card"
                {% if block.settings.url != blank %}target="_blank" rel="noopener noreferrer"{% endif %}
              >
                {% case block.settings.network %}
                  {% when 'facebook' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                  {% when 'instagram' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
                  {% when 'linkedin' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 11v6M8 8v.01M12 17v-4c0-1.1.9-2 2-2s2 .9 2 2v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  {% when 'youtube' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="6" width="20" height="12" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="m10 10 4 2-4 2v-4z" fill="currentColor"/></svg>
                {% endcase %}
                <span>{{ block.settings.title | escape }}</span>
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="kaza-footer__bar">
    <div class="kaza-container">
      <div class="kaza-footer__bar-divider">
        {% if section.settings.show_back_to_top %}
          <button type="button" class="kaza-footer__back-to-top" data-kaza-back-to-top aria-label="{{ 'sections.kaza_footer.back_to_top' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        {% endif %}
      </div>

      <div class="kaza-footer__bar-inner">
        <p class="kaza-footer__copyright">{{ section.settings.copyright_text }}</p>
        <nav class="kaza-footer__legal" aria-label="{{ 'sections.kaza_footer.legal_navigation' | t }}">
          {% if section.settings.legal_menu != blank %}
            {% for link in section.settings.legal_menu.links %}
              <a href="{{ link.url }}">{{ link.title | escape }}</a>
            {% endfor %}
          {% else %}
            {% if section.settings.legal_terms_label != blank %}
              <a href="{{ section.settings.legal_terms_url | default: '#' }}">{{ section.settings.legal_terms_label }}</a>
            {% endif %}
            {% if section.settings.legal_privacy_label != blank %}
              <a href="{{ section.settings.legal_privacy_url | default: '#' }}">{{ section.settings.legal_privacy_label }}</a>
            {% endif %}
            {% if section.settings.legal_cookie_label != blank %}
              <a href="{{ section.settings.legal_cookie_url | default: '#' }}">{{ section.settings.legal_cookie_label }}</a>
            {% endif %}
          {% endif %}
        </nav>
      </div>
    </div>
  </div>
</footer>

{% javascript %}
  (function () {
    const button = document.querySelector('[data-kaza-back-to-top]');
    if (!button) return;
    button.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.kaza_footer.name",
  "max_blocks": 12,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "t:labels.logo_text",
      "default": "KAZA™"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description",
      "default": "Kaza Gives You a Science-backed Way to Take Control of Thin Before It Becomes Noticeable. Stronger Roots. Thicker Growth. Real Confidence."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:labels.cta_label",
      "default": "Get the serum"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:labels.cta_url"
    },
    {
      "type": "header",
      "content": "t:sections.kaza_footer.settings.navigation_header"
    },
    {
      "type": "text",
      "id": "navigation_heading",
      "label": "t:sections.kaza_footer.settings.navigation_heading",
      "default": "Navigation"
    },
    {
      "type": "link_list",
      "id": "navigation_menu",
      "label": "t:sections.kaza_footer.settings.navigation_menu"
    },
    {
      "type": "header",
      "content": "t:sections.kaza_footer.settings.contact_header"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "t:sections.kaza_footer.settings.contact_heading",
      "default": "Contact us"
    },
    {
      "type": "text",
      "id": "office_sublabel",
      "label": "t:sections.kaza_footer.settings.office_sublabel",
      "default": "Visit our office"
    },
    {
      "type": "text",
      "id": "office_text",
      "label": "t:sections.kaza_footer.settings.office_text",
      "default": "Loreum ipsum dol-"
    },
    {
      "type": "text",
      "id": "email_sublabel",
      "label": "t:sections.kaza_footer.settings.email_sublabel",
      "default": "Phone number"
    },
    {
      "type": "text",
      "id": "email",
      "label": "t:sections.kaza_footer.settings.email",
