    {
      "type": "text",
      "id": "language_sublabel",
      "label": "t:sections.kaza_footer.settings.language_sublabel",
      "default": "Language"
    },
    {
      "type": "text",
      "id": "language_text",
      "label": "t:sections.kaza_footer.settings.language_text",
      "default": "English (USA)"
    },
    {
      "type": "header",
      "content": "t:sections.kaza_footer.settings.social_header"
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "t:sections.kaza_footer.settings.social_heading",
      "default": "Social media"
    },
    {
      "type": "header",
      "content": "t:sections.kaza_footer.settings.bar_header"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "t:sections.kaza_footer.settings.copyright_text",
      "default": "Copyright © 2025 BY KATA - All Rights Reserved."
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "t:sections.kaza_footer.settings.legal_menu"
    },
    {
      "type": "text",
      "id": "legal_terms_label",
      "label": "t:sections.kaza_footer.settings.legal_terms_label",
      "default": "Terms of service"
    },
    {
      "type": "url",
      "id": "legal_terms_url",
      "label": "t:sections.kaza_footer.settings.legal_terms_url"
    },
    {
      "type": "text",
      "id": "legal_privacy_label",
      "label": "t:sections.kaza_footer.settings.legal_privacy_label",
      "default": "Privacy policy"
    },
    {
      "type": "url",
      "id": "legal_privacy_url",
      "label": "t:sections.kaza_footer.settings.legal_privacy_url"
    },
    {
      "type": "text",
      "id": "legal_cookie_label",
      "label": "t:sections.kaza_footer.settings.legal_cookie_label",
      "default": "Cookie policy"
    },
    {
      "type": "url",
      "id": "legal_cookie_url",
      "label": "t:sections.kaza_footer.settings.legal_cookie_url"
