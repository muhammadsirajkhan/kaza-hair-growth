        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:labels.button_url"
        }
      ]
    },
    {
      "type": "social_link",
      "name": "t:sections.kaza_footer.blocks.social_link.name",
      "settings": [
        {
          "type": "select",
          "id": "network",
          "label": "t:sections.kaza_footer.blocks.social_link.settings.network",
          "options": [
            { "value": "facebook", "label": "Facebook" },
            { "value": "instagram", "label": "Instagram" },
            { "value": "linkedin", "label": "LinkedIn" },
            { "value": "youtube", "label": "YouTube" }
          ],
          "default": "facebook"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Facebook"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:labels.button_url"
        }
      ]
