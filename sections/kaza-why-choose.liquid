<section class="kaza-why-choose full-width">
  <div class="kaza-container">
    {% if section.settings.heading != blank %}
      <h2 class="kaza-section-heading kaza-why-choose__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="kaza-why-choose__hero">
      {% if section.settings.center_image != blank %}
        {{ section.settings.center_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.heading, class: 'kaza-why-choose__portrait' }}
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'kaza-why-choose__placeholder' }}
      {% endif %}

      {% for block in section.blocks %}
        {% if block.type == 'floating' %}
          <div class="kaza-why-choose__float kaza-why-choose__float--{{ forloop.index }}" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              {{ block.settings.icon | image_url: width: 48 | image_tag: loading: 'lazy', alt: '' }}
            {% endif %}
            <span>{{ block.settings.text }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="kaza-why-choose__cards">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <div class="kaza-card kaza-why-choose__card" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <div class="kaza-why-choose__card-icon">
                {{ block.settings.icon | image_url: width: 48 | image_tag: loading: 'lazy', alt: '' }}
              </div>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="kaza-why-choose__card-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="kaza-why-choose__card-text">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>


{% schema %}
{
  "name": "t:sections.kaza_why_choose.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Why choose Kaza™"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "t:labels.center_image"
    }
  ],
  "blocks": [
    {
      "type": "floating",
      "name": "t:sections.kaza_why_choose.blocks.floating.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text",
          "default": "Safe for all hair types"
        }
      ]
    },
    {
      "type": "feature",
      "name": "t:sections.kaza_why_choose.blocks.feature.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Visible results in 90 days"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "Our clinically tested formula delivers measurable hair growth within three months of consistent use."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_why_choose.name",
      "blocks": [
        { "type": "floating", "settings": { "text": "Clinically proven" } },
        { "type": "floating", "settings": { "text": "Natural ingredients" } },
        { "type": "floating", "settings": { "text": "No side effects" } },
        { "type": "floating", "settings": { "text": "Safe for all hair types" } },
        { "type": "feature", "settings": { "title": "Visible results in 90 days", "text": "Our clinically tested formula delivers measurable hair growth within three months." } },
        { "type": "feature", "settings": { "title": "Natural plant science", "text": "Powered by Rootalix™, our proprietary blend of bio-active botanicals." } },
        { "type": "feature", "settings": { "title": "No prescription needed", "text": "Get started today — no doctor visit or prescription required." } }
      ]
    }
  ]
}
{% endschema %}
