<section class="kaza-why-choose full-width">
  <div class="kaza-why-choose__bg" aria-hidden="true">
    {% if section.settings.background_image != blank %}
      {{ section.settings.background_image | image_url: width: 2400 | image_tag: loading: 'lazy', alt: '' }}
    {% else %}
      <img
        src="{{ 'choose-bg.webp' | asset_url }}"
        alt=""
        width="2400"
        height="1350"
        loading="lazy"
      >
    {% endif %}
  </div>

  <div class="kaza-container kaza-why-choose__inner">
    <div class="kaza-why-choose__header">
      {% if section.settings.badge_text != blank %}
        <span class="kaza-why-choose__badge">{{ section.settings.badge_text }}</span>
      {% endif %}

      {% if section.settings.heading_prefix != blank or section.settings.heading_highlight != blank %}
        <h2 class="kaza-why-choose__heading">
          {% if section.settings.heading_prefix != blank %}
            <span class="kaza-why-choose__heading-prefix">{{ section.settings.heading_prefix }}</span>
          {% endif %}
          {% if section.settings.heading_highlight != blank %}
            <span class="kaza-why-choose__heading-highlight">{{ section.settings.heading_highlight }}</span>
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="kaza-section-subheading kaza-why-choose__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="kaza-why-choose__visual">
      {% if section.settings.show_arc %}
        <svg class="kaza-why-choose__arc" viewBox="0 0 1200 220" preserveAspectRatio="none" aria-hidden="true" focusable="false">
          <path
            d="M -20 150 C 180 40, 420 40, 600 95 S 980 170, 1220 80"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-dasharray="5 7"
            vector-effect="non-scaling-stroke"
          />
          <circle cx="120" cy="118" r="3.5" fill="currentColor" />
          <circle cx="360" cy="52" r="3.5" fill="currentColor" />
          <circle cx="600" cy="95" r="3.5" fill="currentColor" />
          <circle cx="840" cy="138" r="3.5" fill="currentColor" />
          <circle cx="1080" cy="98" r="3.5" fill="currentColor" />
        </svg>
      {% endif %}

      <div class="kaza-why-choose__portrait-wrap">
        {% if section.settings.center_image != blank %}
          {{ section.settings.center_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: section.settings.heading_highlight, class: 'kaza-why-choose__portrait' }}
        {% else %}
          <img
            src="{{ 'choose-image.webp' | asset_url }}"
            alt="{{ section.settings.heading_highlight | escape }}"
            class="kaza-why-choose__portrait"
            width="700"
            height="900"
            loading="lazy"
          >
        {% endif %}
      </div>

      <div class="kaza-why-choose__floats">
        {% for block in section.blocks %}
          {% if block.type == 'floating' %}
            {% liquid
              assign float_icon = block.settings.icon
              if float_icon == blank
                case block.settings.position
                  when 'top-left'
                    assign float_icon_fallback = 'choose-icon1.webp'
                  when 'bottom-left'
                    assign float_icon_fallback = 'choose-icon2.webp'
                  when 'top-right'
                    assign float_icon_fallback = 'choose-icon3.webp'
                  when 'bottom-right'
                    assign float_icon_fallback = 'choose-icon4.webp'
                  else
                    assign float_icon_fallback = 'choose-icon1.webp'
                endcase
              endif
            %}
            <div
              class="kaza-why-choose__float kaza-why-choose__float--{{ block.settings.position }}"
              {{ block.shopify_attributes }}
            >
              {% if float_icon != blank %}
                {{ float_icon | image_url: width: 48 | image_tag: loading: 'lazy', alt: '' }}
              {% else %}
                <img
                  src="{{ float_icon_fallback | asset_url }}"
                  alt=""
                  width="24"
                  height="24"
                  loading="lazy"
                >
              {% endif %}
              {% if block.settings.text != blank %}
                <span>{{ block.settings.text }}</span>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="kaza-why-choose__cards">
      {% assign feature_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          {% assign feature_index = feature_index | plus: 1 %}
          {% liquid
            assign feature_icon = block.settings.icon
            if feature_icon == blank
              case feature_index
                when 1
                  assign feature_icon_fallback = 'choose-1.webp'
                when 2
                  assign feature_icon_fallback = 'choose-2.webp'
                when 3
                  assign feature_icon_fallback = 'choose-3.webp'
                else
                  assign feature_icon_fallback = 'choose-1.webp'
              endcase
            endif
          %}
          <article class="kaza-card kaza-why-choose__card" {{ block.shopify_attributes }}>
            <div class="kaza-why-choose__card-icon">
              {% if feature_icon != blank %}
                {{ feature_icon | image_url: width: 64 | image_tag: loading: 'lazy', alt: '' }}
              {% else %}
                <img
                  src="{{ feature_icon_fallback | asset_url }}"
                  alt=""
                  width="32"
                  height="32"
                  loading="lazy"
                >
              {% endif %}
            </div>
            {% if block.settings.title != blank %}
              <h3 class="kaza-why-choose__card-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="kaza-why-choose__card-text">{{ block.settings.text }}</p>
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.kaza_why_choose.name",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:sections.kaza_why_choose.settings.badge_text",
      "default": "Welcome to Kaza"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "t:sections.kaza_why_choose.settings.heading_prefix",
      "default": "Why Choose"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "t:sections.kaza_why_choose.settings.heading_highlight",
      "default": "Kaza™"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.kaza_why_choose.settings.subheading",
      "default": "Real performance. Visible results. Made for men who want impact, not excuses."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:labels.background_image"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "t:labels.center_image"
    },
    {
      "type": "checkbox",
      "id": "show_arc",
      "label": "t:sections.kaza_why_choose.settings.show_arc",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "floating",
      "name": "t:sections.kaza_why_choose.blocks.floating.name",
      "settings": [
        {
          "type": "select",
          "id": "position",
          "label": "t:labels.position",
          "options": [
            { "value": "top-left", "label": "t:options.position.top_left" },
            { "value": "bottom-left", "label": "t:options.position.bottom_left" },
            { "value": "top-right", "label": "t:options.position.top_right" },
            { "value": "bottom-right", "label": "t:options.position.bottom_right" }
          ],
          "default": "top-left"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text",
          "default": "Instantly Activates the follicle"
        }
      ]
    },
    {
      "type": "feature",
      "name": "t:sections.kaza_why_choose.blocks.feature.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Follicle vitality support"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "A next-gen catechin system (DHQG + EGCG) paired with Zinc PCA to support a balanced scalp environment and the look of active, energized roots."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_why_choose.name",
      "blocks": [
        {
          "type": "floating",
          "settings": {
            "position": "top-left",
            "text": "Instantly Activates the follicle"
          }
        },
        {
          "type": "floating",
          "settings": {
            "position": "bottom-left",
            "text": "Reduces shedding"
          }
        },
        {
          "type": "floating",
          "settings": {
            "position": "top-right",
            "text": "Supports fuller Density"
          }
        },
        {
          "type": "floating",
          "settings": {
            "position": "bottom-right",
            "text": "Visible Density Improvements"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Follicle vitality support",
            "text": "A next-gen catechin system (DHQG + EGCG) paired with Zinc PCA to support a balanced scalp environment and the look of active, energized roots."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Root anchoring appearance",
            "text": "Oleanolic acid + apigenin + a peptide (biotinoyl tripeptide-1) to support the look of stronger, better-anchored hair at the scalp surface."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Optimized delivery",
            "text": "Formulated in a lightweight, leave-on base (with DMI + diols) that dries fast and keeps actives where you want them—on your scalp, not your pillow."
          }
        }
      ]
    }
  ]
}
{% endschema %}
