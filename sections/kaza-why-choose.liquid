<section class="kaza-why-choose full-width">
  <div class="kaza-container">
    {% if section.settings.heading != blank %}
      <h2 class="kaza-section-heading kaza-why-choose__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="kaza-why-choose__hero">
      {% if section.settings.center_image != blank %}
        {{ section.settings.center_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: section.settings.heading, class: 'kaza-why-choose__portrait' }}
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'kaza-why-choose__placeholder' }}
      {% endif %}

      {% for block in section.blocks %}
        {% if block.type == 'floating' %}
          <div class="kaza-why-choose__float kaza-why-choose__float--{{ forloop.index }}" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              {{ block.settings.icon | image_url: width: 48 | image_tag: loading: 'lazy', alt: '' }}
            {% endif %}
            <span>{{ block.settings.text }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="kaza-why-choose__cards">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <div class="kaza-card kaza-why-choose__card" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <div class="kaza-why-choose__card-icon">
                {{ block.settings.icon | image_url: width: 48 | image_tag: loading: 'lazy', alt: '' }}
              </div>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="kaza-why-choose__card-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="kaza-why-choose__card-text">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .kaza-why-choose {
    padding-block: var(--kaza-section-y);
    background: var(--kaza-beige);
  }

  .kaza-why-choose__heading {
    text-align: center;
    margin-bottom: 3rem;
  }

  .kaza-why-choose__hero {
    position: relative;
    display: flex;
    justify-content: center;
    margin-bottom: 3rem;
    min-height: 320px;
  }

  .kaza-why-choose__portrait {
    max-height: 380px;
    width: auto;
    border-radius: var(--kaza-radius-card);
    object-fit: cover;
  }

  .kaza-why-choose__placeholder {
    max-height: 380px;
    width: auto;
    border-radius: var(--kaza-radius-card);
  }

  .kaza-why-choose__float {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: var(--kaza-white);
    border-radius: var(--kaza-radius-pill);
    box-shadow: var(--kaza-shadow-card);
    font-size: 0.75rem;
    font-weight: 600;
    max-width: 10rem;
    line-height: 1.3;
  }

  .kaza-why-choose__float img {
    width: 1.5rem;
    height: 1.5rem;
    object-fit: contain;
  }

  .kaza-why-choose__float--1 { top: 10%; left: 5%; }
  .kaza-why-choose__float--2 { top: 15%; right: 5%; }
  .kaza-why-choose__float--3 { bottom: 20%; left: 8%; }
  .kaza-why-choose__float--4 { bottom: 15%; right: 8%; }

  .kaza-why-choose__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .kaza-why-choose__card {
    padding: 2rem;
  }

  .kaza-why-choose__card-icon {
    margin-bottom: 1rem;
  }

  .kaza-why-choose__card-icon img {
    width: 2rem;
    height: 2rem;
    object-fit: contain;
  }

  .kaza-why-choose__card-title {
    font-size: 1.0625rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .kaza-why-choose__card-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--kaza-gray);
  }

  @media (max-width: 767px) {
    .kaza-why-choose__float {
      position: static;
      max-width: none;
      margin-bottom: 0.5rem;
    }

    .kaza-why-choose__hero {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      min-height: auto;
    }

    .kaza-why-choose__cards {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.kaza_why_choose.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Why choose Kaza™"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "t:labels.center_image"
    }
  ],
  "blocks": [
    {
      "type": "floating",
      "name": "t:sections.kaza_why_choose.blocks.floating.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text",
          "default": "Safe for all hair types"
        }
      ]
    },
    {
      "type": "feature",
      "name": "t:sections.kaza_why_choose.blocks.feature.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Visible results in 90 days"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "Our clinically tested formula delivers measurable hair growth within three months of consistent use."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_why_choose.name",
      "blocks": [
        { "type": "floating", "settings": { "text": "Clinically proven" } },
        { "type": "floating", "settings": { "text": "Natural ingredients" } },
        { "type": "floating", "settings": { "text": "No side effects" } },
        { "type": "floating", "settings": { "text": "Safe for all hair types" } },
        { "type": "feature", "settings": { "title": "Visible results in 90 days", "text": "Our clinically tested formula delivers measurable hair growth within three months." } },
        { "type": "feature", "settings": { "title": "Natural plant science", "text": "Powered by Rootalix™, our proprietary blend of bio-active botanicals." } },
        { "type": "feature", "settings": { "title": "No prescription needed", "text": "Get started today — no doctor visit or prescription required." } }
      ]
    }
  ]
}
{% endschema %}
