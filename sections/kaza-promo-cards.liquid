<section class="kaza-promo-cards full-width">
  <div class="kaza-container">
    <div class="kaza-promo-cards__grid">
      {% for block in section.blocks %}
        {% liquid
          assign card_bg = block.settings.background_image
          if card_bg == blank
            if block.settings.card_layout == 'right'
              assign card_bg_fallback = 'right-bg.webp'
            else
              assign card_bg_fallback = 'left-bg.webp'
            endif
          endif
        %}
        <article
          class="kaza-promo-cards__card kaza-promo-cards__card--{{ block.settings.card_layout }}"
          {{ block.shopify_attributes }}
        >
          <div class="kaza-promo-cards__bg" aria-hidden="true">
            {% if card_bg != blank %}
              {{ card_bg | image_url: width: 1200 | image_tag: loading: 'lazy', alt: '' }}
            {% else %}
              <img
                src="{{ card_bg_fallback | asset_url }}"
                alt=""
                width="1200"
                height="900"
                loading="lazy"
              >
            {% endif %}
          </div>

          <div class="kaza-promo-cards__body">
            {% if block.settings.heading_prefix != blank or block.settings.heading_highlight != blank %}
              <h3 class="kaza-promo-cards__heading">
                {% if block.settings.heading_prefix != blank %}
                  <span class="kaza-section-heading__prefix">{{ block.settings.heading_prefix }}</span>
                {% endif %}
                {% if block.settings.heading_highlight != blank %}
                  <span class="kaza-section-heading__highlight">{{ block.settings.heading_highlight }}</span>
                {% endif %}
              </h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="kaza-promo-cards__text">{{ block.settings.text }}</p>
            {% endif %}
            {% if block.settings.button_label != blank %}
              {% render 'kaza-button',
                label: block.settings.button_label,
                url: block.settings.button_url,
                style: 'primary',
                class: 'kaza-promo-cards__btn'
              %}
            {% endif %}
          </div>

          {% if block.settings.show_badges %}
            <div class="kaza-promo-cards__badges" aria-hidden="true">
              {% if block.settings.badge_1_text != blank %}
                <div class="kaza-promo-cards__badge kaza-promo-cards__badge--1">
                  {% if block.settings.badge_1_icon != blank %}
                    {{ block.settings.badge_1_icon | image_url: width: 32 | image_tag: loading: 'lazy', alt: '' }}
                  {% else %}
                    <img src="{{ 'choose-icon4.webp' | asset_url }}" alt="" width="14" height="14" loading="lazy">
                  {% endif %}
                  <span>{{ block.settings.badge_1_text }}</span>
                </div>
              {% endif %}
              {% if block.settings.badge_2_text != blank %}
                <div class="kaza-promo-cards__badge kaza-promo-cards__badge--2">
                  {% if block.settings.badge_2_icon != blank %}
                    {{ block.settings.badge_2_icon | image_url: width: 32 | image_tag: loading: 'lazy', alt: '' }}
                  {% else %}
                    <img src="{{ 'choose-icon3.webp' | asset_url }}" alt="" width="14" height="14" loading="lazy">
                  {% endif %}
                  <span>{{ block.settings.badge_2_text }}</span>
                </div>
              {% endif %}
            </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.kaza_promo_cards.name",
  "max_blocks": 2,
  "blocks": [
    {
      "type": "card",
      "name": "t:sections.kaza_promo_cards.blocks.card.name",
      "settings": [
        {
          "type": "select",
          "id": "card_layout",
          "label": "t:sections.kaza_promo_cards.settings.card_layout",
          "options": [
            { "value": "left", "label": "t:sections.kaza_promo_cards.settings.card_layout_left" },
            { "value": "right", "label": "t:sections.kaza_promo_cards.settings.card_layout_right" }
          ],
          "default": "left"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "t:labels.background_image"
        },
        {
          "type": "text",
          "id": "heading_prefix",
          "label": "t:labels.heading_prefix",
          "default": "No Prescription "
        },
        {
          "type": "text",
          "id": "heading_highlight",
          "label": "t:labels.heading_highlight",
          "default": "Needed."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "Non-systemic, zero libido impact, no prescription needed."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:labels.button_label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "t:labels.button_url"
        },
        {
          "type": "checkbox",
          "id": "show_badges",
          "label": "t:sections.kaza_promo_cards.settings.show_badges",
          "default": false
        },
        {
          "type": "text",
          "id": "badge_1_text",
          "label": "t:sections.kaza_promo_cards.settings.badge_1_text",
          "default": "Visible Density Improvements."
        },
        {
          "type": "image_picker",
          "id": "badge_1_icon",
          "label": "t:sections.kaza_promo_cards.settings.badge_1_icon"
        },
        {
          "type": "text",
          "id": "badge_2_text",
          "label": "t:sections.kaza_promo_cards.settings.badge_2_text",
          "default": "Supports Fuller Density"
        },
        {
          "type": "image_picker",
          "id": "badge_2_icon",
          "label": "t:sections.kaza_promo_cards.settings.badge_2_icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_promo_cards.name",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "card_layout": "left",
            "heading_prefix": "No Prescription ",
            "heading_highlight": "Needed.",
            "text": "Non-systemic, zero libido impact, no prescription needed.",
            "button_label": "Shop Now"
          }
        },
        {
          "type": "card",
          "settings": {
            "card_layout": "right",
            "heading_prefix": "Bio-Hacked ",
            "heading_highlight": "Plant Science",
            "text": "Saw Palmetto, Green Tea, Larch Wood, Oleanolic Acid are all botanical-derived.",
            "button_label": "Shop Now",
            "show_badges": true,
            "badge_1_text": "Visible Density Improvements.",
            "badge_2_text": "Supports Fuller Density"
          }
        }
      ]
    }
  ]
}
{% endschema %}
