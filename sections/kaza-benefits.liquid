<section class="kaza-benefits full-width">
  <div class="kaza-container">
    <div class="kaza-benefits__grid">
      {% for block in section.blocks %}
        <div class="kaza-card kaza-benefits__card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="kaza-benefits__icon">
              {{ block.settings.icon | image_url: width: 48 | image_tag: loading: 'lazy', alt: '' }}
            </div>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="kaza-benefits__title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="kaza-benefits__text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .kaza-benefits {
    padding-block: var(--kaza-section-y);
    background: var(--kaza-beige);
  }

  .kaza-benefits__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .kaza-benefits__card {
    padding: 1.75rem;
    text-align: center;
  }

  .kaza-benefits__icon {
    margin-bottom: 1rem;
  }

  .kaza-benefits__icon img {
    width: 2rem;
    height: 2rem;
    margin-inline: auto;
    object-fit: contain;
  }

  .kaza-benefits__title {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .kaza-benefits__text {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--kaza-gray);
  }

  @media (max-width: 1023px) {
    .kaza-benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .kaza-benefits__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.kaza_benefits.name",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "benefit",
      "name": "t:sections.kaza_benefits.blocks.benefit.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Fast shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_benefits.name",
      "blocks": [
        { "type": "benefit", "settings": { "title": "Fast shipping", "text": "Free shipping on all orders" } },
        { "type": "benefit", "settings": { "title": "90-day money back", "text": "Full refund if not satisfied" } },
        { "type": "benefit", "settings": { "title": "Secure payment", "text": "256-bit SSL encryption" } },
        { "type": "benefit", "settings": { "title": "24/7 support", "text": "We're here to help anytime" } }
      ]
    }
  ]
}
{% endschema %}
