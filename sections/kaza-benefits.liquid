<section class="kaza-benefits full-width">
  <div class="kaza-container">
    <div class="kaza-benefits__grid">
      {% for block in section.blocks %}
        <div class="kaza-card kaza-benefits__card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="kaza-benefits__icon">
              {{ block.settings.icon | image_url: width: 48 | image_tag: loading: 'lazy', alt: '' }}
            </div>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="kaza-benefits__title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="kaza-benefits__text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>


{% schema %}
{
  "name": "t:sections.kaza_benefits.name",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "benefit",
      "name": "t:sections.kaza_benefits.blocks.benefit.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Fast shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_benefits.name",
      "blocks": [
        { "type": "benefit", "settings": { "title": "Fast shipping", "text": "Free shipping on all orders" } },
        { "type": "benefit", "settings": { "title": "90-day money back", "text": "Full refund if not satisfied" } },
        { "type": "benefit", "settings": { "title": "Secure payment", "text": "256-bit SSL encryption" } },
        { "type": "benefit", "settings": { "title": "24/7 support", "text": "We're here to help anytime" } }
      ]
    }
  ]
}
{% endschema %}
