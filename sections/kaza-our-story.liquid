<section class="kaza-our-story full-width">
  <div class="kaza-container">
    {% if section.settings.show_intro %}
      <div class="kaza-our-story__intro">
        {% if section.settings.badge_text != blank %}
          <span class="kaza-our-story__badge">{{ section.settings.badge_text }}</span>
        {% endif %}

        {% if section.settings.intro_text != blank %}
          <p class="kaza-our-story__intro-text">{{ section.settings.intro_text }}</p>
        {% endif %}

        <div class="kaza-our-story__divider" aria-hidden="true"></div>
      </div>
    {% endif %}

    <div class="kaza-our-story__grid">
      <div class="kaza-our-story__media">
        <figure class="kaza-our-story__media-frame">
          {% if section.settings.image_label != blank %}
            <figcaption class="kaza-our-story__media-label">
              <span>{{ section.settings.image_label }}</span>
            </figcaption>
          {% endif %}

          <div class="kaza-our-story__media-image">
            {% if section.settings.image != blank %}
              {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.heading, class: 'kaza-our-story__image' }}
            {% else %}
              <img
                src="{{ 'story.webp' | asset_url }}"
                alt="{{ section.settings.heading | escape }}"
                class="kaza-our-story__image"
                width="900"
                height="1125"
                loading="lazy"
              >
            {% endif %}
          </div>
        </figure>
      </div>

      <div class="kaza-our-story__content">
        {% if section.settings.heading != blank %}
          <h2 class="kaza-our-story__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="kaza-our-story__text">{{ section.settings.text }}</div>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a
            href="{{ section.settings.button_url | default: '#' }}"
            class="kaza-btn kaza-btn--primary kaza-our-story__cta"
          >
            {{ section.settings.button_label }}
            <svg class="kaza-our-story__cta-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.show_rating %}
          <div class="kaza-our-story__rating">
            {% render 'kaza-star-rating', rating: section.settings.rating, label: section.settings.rating_text %}
            {% if section.settings.rating_text != blank %}
              <span class="kaza-our-story__rating-text">{{ section.settings.rating_text }}</span>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.kaza_our_story.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.kaza_our_story.settings.intro_header"
    },
    {
      "type": "checkbox",
      "id": "show_intro",
      "label": "t:sections.kaza_our_story.settings.show_intro",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:sections.kaza_our_story.settings.badge_text",
      "default": "Welcome to Kaza"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "t:sections.kaza_our_story.settings.intro_text",
      "default": "Kaza is built for men who take their appearance seriously and want products that match that mindset — clean, modern, and engineered to work."
    },
    {
      "type": "header",
      "content": "t:sections.kaza_our_story.settings.story_header"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "image_label",
      "label": "t:sections.kaza_our_story.settings.image_label",
      "default": "Welcome to Kaza"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Our story"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:labels.text",
      "default": "<p>Kaza was created with a simple objective: give men a hair growth solution that actually performs. No gimmicks. No empty promises. Just real science, clean formulation, and measurable results.</p><p>We focus on early-stage thinning — the point where action matters most. Our serum is powered by Rootalix™, a proprietary botanical-bioactive complex designed to fuel follicle activity, strengthen roots, and support visible density improvements. Every ingredient serves a purpose. Nothing extra. Nothing watered down.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Read About Us"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "t:sections.kaza_our_story.settings.show_rating",
      "default": true
    },
    {
      "type": "range",
      "id": "rating",
      "label": "t:labels.rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "t:labels.rating_text",
      "default": "5000+ Verified 5-star Reviews "
    }
  ],
  "presets": [
    {
      "name": "t:sections.kaza_our_story.name"
    }
  ]
}
{% endschema %}
